# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large raw video sources (not shipped)
video-raw/
.media-src/

# internal project docs (kept out of the public hosting repo)
/PTM_PRD.md
/PLACEHOLDERS.md
/ANIMATION_REFERENCE.md
/rules.md
*.docx

# asset-generation tooling (not needed to build or host on Vercel)
/scripts/
/remotion/

# dev artifacts / scratch
/.playwright-mcp/
/home-hero.png
